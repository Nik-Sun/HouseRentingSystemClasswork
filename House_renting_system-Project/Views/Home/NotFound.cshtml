@{
    ViewData["Title"] = "Page Not Found";
}

<div style="display:flex; justify-content:center; align-items:center; min-height:70vh;">
    <div style="text-align:center; max-width:500px; padding:40px; background:#1e293b; border-radius:12px; color:#e2e8f0; box-shadow:0 10px 30px rgba(0,0,0,0.3);">

        <h1 style="font-size:72px; margin:0; color:#38bdf8;">404</h1>
        <h3 style="margin:10px 0 20px;">Page not found</h3>

        <p style="color:#cbd5f5;">
            The page you're looking for doesn't exist or has been moved.
        </p>

        <a href="/" style="display:inline-block; margin-top:20px; padding:10px 20px; background:#3b82f6; color:white; border-radius:6px; text-decoration:none;">
            Go back home
        </a>

    </div>
</div>